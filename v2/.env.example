# Database (required)
DATABASE_URL=postgresql+asyncpg://ghostwriter:ghostwriter@db:5432/ghostwriter

# Auth toggle — set to true for multi-tenant API-key mode (default: false = single-user)
AUTH_ENABLED=false

# LLM Provider Keys — set at least one to use /generate
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Social scraping (optional — only needed for /source-content/import-* endpoints)
APIFY_API_TOKEN=

# Override default public Apify actor IDs (optional)
# APIFY_LINKEDIN_ACTOR_ID=
# APIFY_YOUTUBE_ACTOR_ID=
