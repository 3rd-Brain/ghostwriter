run = ["uvicorn", "main:app", "--host", "0.0.0.0", "--reload"]
modules = ["python-3.11", "postgresql-16"]

hidden = [".pythonlibs"]

[nix]
channel = "stable-24_05"
packages = ["cargo", "freetype", "gmp", "gumbo", "harfbuzz", "jbig2dec", "libiconv", "libjpeg_turbo", "libxcrypt", "mupdf", "openjpeg", "openssl", "pkg-config", "rustc", "swig", "xcbuild"]

[deployment]
run = ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080"]
deploymentTarget = "cloudrun"

[env]
REPLIT_DISABLE_PACKAGE_LAYER = "1"

[objectStorage]
defaultBucketID = "replit-objstore-79c8cd88-525c-4883-857a-badfc3b09dba"

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 80

[workflows]
runButton = "Run"

[[workflows.workflow]]
name = "Run"
author = 39776920
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pip install -r requirements.txt"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uvicorn main:app --host 0.0.0.0 --reload"

[[workflows.workflow]]
name = "Pricing Config Manager"
mode = "sequential"
author = 39776920

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python admin_scripts/pricing_config_manager.py"
